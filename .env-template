# LLM provider: "groq" (free, default), "gemini", "openai", or "anthropic"
LLM_PROVIDER=groq

# Groq API key (required if LLM_PROVIDER=groq)
# Free tier, no credit card, ~1,000 requests/day -- get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini API key (required if LLM_PROVIDER=gemini)
# Free tier, no credit card, but only ~20 requests/day -- https://aistudio.google.com
GOOGLE_API_KEY=...

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Web search uses DuckDuckGo (no API key required).
